---
import Layout from "../layouts/Layout.astro";
import heroImage from "/public/images/hero-kunsthal.webp";
import "../styles/kunsthal.css";
---

<Layout title="Brantebjerg">
  <section class="hero">
    <!-- HERO BILLEDE -->
    <img src="/images/hero-kunsthal.webp" alt="BB Kunsthal" class="hero-image" />

    <div class="hero-overlay"></div>

    <div class="hero-content">
      <h1>BB Kunsthal</h1>

      <p>Et levende kreativt kunstmiljø</p>
    </div>
  </section>

  <!-- GALLERI -->
  <section class="kunsthal-section art-bg">
    <div class="two-column">
      <div class="text-box">
        <h2>Om Galleri</h2>

        <h3>Et levende kunstmiljø</h3>

        <p>Lorem ipsum dolor sit amet consectetur adipisicing elit.</p>

        <a class="cta-btn" href="/kunsthal-galleri"> Til galleri → </a>
      </div>

      <div></div>
    </div>
  </section>

  <!-- MAD -->
  <section class="kunsthal-section food-bg">
    <div class="two-column">
      <div></div>

      <div class="text-box">
        <h2>Mad & Oplevelser</h2>

        <h3>Om</h3>

        <p>Lorem ipsum dolor sit amet consectetur adipisicing elit.</p>
      </div>
    </div>
  </section>

  <!-- MENU -->
  <section class="kunsthal-section menu-bg">
    <div class="two-column">
      <div class="text-box">
        <h2>Menu</h2>

        <ul>
          <li>Kaffe</li>
          <li>Kage</li>
          <li>Sandwich</li>
          <li>Vegetarisk</li>
          <li>Kolde drikke</li>
        </ul>
      </div>

      <div></div>
    </div>
  </section>

  <!-- OPHOLD -->
  <section class="kunsthal-section stay-bg">
    <div class="two-column">
      <div></div>

      <div class="text-box">
        <h2>Ophold</h2>

        <h3>Bo midt i oplevelsen</h3>

        <p>Lorem ipsum dolor sit amet consectetur adipisicing elit.</p>

        <a class="cta-btn" href="/booking"> Til booking → </a>
      </div>
    </div>
  </section></Layout
>
