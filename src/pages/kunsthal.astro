---
import Layout from "../layouts/Layout.astro";

import "../styles/global.css";
import "../styles/kunsthal.css";

import ImgButton from "../components/ImgButton.astro";
import Divider from "../components/Divider.astro";
---

<Layout title="Brantebjerg Kunsthal">
  <section class="hero">
    <div class="hero-image"></div>

    <div class="hero-content">
      <h1>
        Brantebjerg<br />
        Kunsthal
      </h1>

      <p class="hero-subtitle">Nakke Nord 65, 4500</p>
    </div>

    <div class="hero-overlay"></div>
  </section>

  <Divider />

  <section class="page-section art-bg">
    <div class="section-grid">
      <div class="section-text">
        <h2>Art Collection</h2>

        <h3>
          See the sprawling art exhibited in<br />
          Brantebjerg Kunsthal's raw architecture
        </h3>

        <ImgButton href="/kunsthal-galleri" imgSrc="/icons/kh_exploregallery_cta.png" hoverSrc="/icons/kh_exploregallery_cta_h.png" alt="Explore gallery" />
      </div>

      <div>
        <img class="showcase-image" src="/images/gallery.webp" alt="" />
      </div>
    </div>
  </section>

  <Divider />

  <!-- FOOD -->

  <section class="page-section food-bg">
    <div class="section-grid">
      <div>
        <img class="showcase-image" src="/images/food.webp" alt="" />
      </div>

      <div class="section-text">
        <h2>Food</h2>

        <h3>Enjoy a meal.</h3>

        <p>Besides the art and surroundings, Brantebjerg also offers food and drinks.</p>

        <p>Enjoy local ingredients and seasonal produce.</p>

        <!-- MENU BUTTONS -->

        <div class="menu-buttons">
          <img id="foodBtn" class="menu-trigger" src="/images/menu3.png" alt="Food menu" />

          <img id="drinkBtn" class="menu-trigger" src="/images/menu3.png" alt="Drink menu" />
        </div>
      </div>
    </div>
  </section>

  <!-- FOOD POPUP -->

  <div id="foodPopup" class="popup">
    <div class="popup-content">
      <span class="close" data-close="foodPopup">&times;</span>

      <img src="/images/menu1.webp" alt="Food menu" />
    </div>
  </div>

  <!-- DRINK POPUP -->

  <div id="drinkPopup" class="popup">
    <div class="popup-content">
      <span class="close" data-close="drinkPopup">&times;</span>

      <img src="/images/menu2.webp" alt="Drink menu" />
    </div>
  </div>

  <script>
    const foodBtn = document.getElementById("foodBtn");
    const drinkBtn = document.getElementById("drinkBtn");

    const foodPopup = document.getElementById("foodPopup");
    const drinkPopup = document.getElementById("drinkPopup");

    if (foodBtn && foodPopup) {
      foodBtn.addEventListener("click", () => {
        foodPopup.style.display = "flex";
      });
    }

    if (drinkBtn && drinkPopup) {
      drinkBtn.addEventListener("click", () => {
        drinkPopup.style.display = "flex";
      });
    }

    const closeButtons = document.querySelectorAll(".close");

    closeButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const popupId = button.getAttribute("data-close");

        if (popupId) {
          const popup = document.getElementById(popupId);

          if (popup) {
            popup.style.display = "none";
          }
        }
      });
    });

    window.addEventListener("click", (e) => {
      const target = e.target;

      if (target instanceof HTMLElement && target.classList.contains("popup")) {
        target.style.display = "none";
      }
    });
  </script>

  <Divider />

  <!-- STAY -->

  <section class="page-section stay-bg">
    <div class="section-grid">
      <div>
        <img class="showcase-image" src="/images/stay.webp" alt="" />
      </div>

      <div class="section-text">
        <h2>Accommodations</h2>

        <h3>Come and stay</h3>

        <p>If you can't get enough of Brantebjerg, you can book a stay in the guest house.</p>

        <p>Contact: pernellecaspersen@yahoo.dk</p>
      </div>
    </div>
  </section>
</Layout>
