---
import Layout from "../layouts/Layout.astro";

import "../styles/global.css";
import "../styles/kunsthal.css";

import Divider from "../components/Divider.astro";
---

<Layout title="Brantebjerg Kunsthal">
  <section class="hero">
    <div class="hero-image"></div>

    <div class="hero-content">
      <h1>
        Brantebjerg<br>
        Kunsthal
      </h1>

      <p class="hero-subtitle">Nakke Nord 65, 4500</p>
    </div>

    <!-- <div class="hero-overlay"></div> -->

  </section>

  <Divider />

  <!-- ART -->

  <section class="page-section art-bg">
    <div class="section-grid">
      <div class="section-text">
        <h2>Art Collection</h2>

        <h3>
          See the sprawling art exhibited in<br>
          Brantebjerg Kunsthal's raw architecture
        </h3>

        <a href="/kunsthal-galleri"> Kunsthal Gallery → </a>
      </div>

      <div>
        <img src="/images/gallery.webp" alt="" />
      </div>
    </div>
  </section>

  <Divider />

  <!-- FOOD -->

  <section class="page-section food-bg">
    <div class="section-grid">
      <div>
        <img src="/images/food.webp" alt="" />
      </div>

      <div class="section-text">
        <h2>Food</h2>

        <h3>Enjoy a meal.</h3>

        <p>Besides the art and surroundings, Brantebjerg also offers food and drinks.</p>

        <p>Enjoy local ingredients and seasonal produce.</p>

        <a href="#"> Menu popup → </a>
      </div>
    </div>
  </section>

  <Divider />

  <!-- STAY -->

  <section class="page-section stay-bg">
    <div class="section-grid">
      <div>
        <img src="/images/stay.webp" alt="" />
      </div>

      <div class="section-text">
        <h2>Accommodations</h2>

        <h3>Come and stay</h3>

        <p>If you can't get enough of Brantebjerg, you can book a stay in the guest house.</p>

        <p>Contact: pernellecaspersen@yahoo.dk</p>
      </div>
    </div>
  </section>

</Layout>
