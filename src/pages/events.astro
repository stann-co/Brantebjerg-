---
import Layout from "../layouts/Layout.astro";
import "../styles/events.css";

import { getEvents } from "../api/supabase";

const events = await getEvents();

console.log(events);
---

<Layout title="Events">
  <!-- HERO -->

  <section class="events-hero">
    <div class="hero-overlay"></div>

    <div class="events-title">
      <h1>Events</h1>
    </div>
  </section>

  <!-- OPENING HOURS -->

  <section class="opening-section">
    <h2>Our Opening hours</h2>

    <div class="opening-grid">
      <!-- BUREAU -->

      <div class="opening-card">
        <div class="opening-top">
          <div>
            <p>Brantebjerg Bureau</p>

            <span>Tullinsgade 25, 1618</span>
          </div>

          <div>
            <p>Åbningstider:</p>
          </div>
        </div>

        <div class="opening-times">
          <span>Mandag: 11-19</span>
          <span>Tirsdag: 11-19</span>
          <span>Onsdag: 11-19</span>
          <span>Torsdag: 11-19</span>
          <span>Fredag: 11-19</span>
          <span>Lørdag: 11-19</span>
          <span>Søndag: 11-19</span>
        </div>
      </div>

      <!-- KUNSTHAL -->

      <div class="opening-card">
        <div class="opening-top">
          <div>
            <p>Brantebjerg Kunsthal</p>

            <span>Nakke Nord 65, 4500</span>
          </div>

          <div>
            <p>Åbningstider:</p>
          </div>
        </div>

        <div class="opening-times">
          <span>Mandag: 11-19</span>
          <span>Tirsdag: 11-19</span>
          <span>Onsdag: 11-19</span>
          <span>Torsdag: 11-19</span>
          <span>Fredag: 11-19</span>
          <span>Lørdag: 11-19</span>
          <span>Søndag: 11-19</span>
        </div>
      </div>
    </div>
  </section>

  <!-- EVENTS -->

  <section class="events-section">
    <div class="events-top">
      <select>
        <option>Filter</option>
      </select>

      <h2>Upcoming events</h2>
    </div>

    <div class="events-grid">
      {
        events.map((event: any) => (
          <article class="event-card">
            <div class="event-info">
              <div class="event-left">
                <span>{event.title || event.event_name || "Event navn"}</span>

                <span>{event.date || event.time_date || event.datetime || "Tid og dato"}</span>

                <span>{event.location || event.place || "Sted"}</span>
              </div>

              <div class="event-right">
                <p>{event.description || event.desc || "Beskrivelse"}</p>
              </div>
            </div>

            <img src={event.picture || event.image || event.image_url} alt={event.title || event.event_name} />
          </article>
        ))
      }
    </div>
  </section>

  <button class="expand-btn">Expand calendar</button>
</Layout>

))

<button class="expand-btn">Expand calendar</button>
