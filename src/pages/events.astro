---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import "../styles/events.css";

import { getEvents } from "../api/supabase";

import Divider from "../components/Divider.astro";

const events = await getEvents();

---

<script>
  window.addEventListener('DOMContentLoaded', () => {
    const filterSelect = document.querySelector('.filter') as HTMLSelectElement;
    const sortSelect = document.querySelector('.sort') as HTMLSelectElement;
    const eventsGrid = document.querySelector('.events-grid');
    const eventCards = Array.from(document.querySelectorAll('.event-card')) as HTMLElement[];

    function filterEvents() {
      const selectedPlace = filterSelect?.value.toLowerCase() || 'all';

      eventCards.forEach((card) => {
        const place = (card.getAttribute('data-place') || '').toLowerCase().trim();
        (card as HTMLElement).style.display =
          selectedPlace === 'all' || selectedPlace === place ? 'block' : 'none';
      });
    }

    function sortEvents() {
      if (!eventsGrid || !sortSelect) return;

      const order = sortSelect.value;
      const sorted = eventCards.slice().sort((a, b) => {
        const aDate = new Date(a.dataset.date || '').getTime();
        const bDate = new Date(b.dataset.date || '').getTime();

        if (Number.isNaN(aDate) || Number.isNaN(bDate)) return 0;
        return order === 'Descending' ? bDate - aDate : aDate - bDate;
      });

      sorted.forEach((card) => eventsGrid.appendChild(card));
    }

    filterSelect?.addEventListener('change', () => {
      filterEvents();
      sortEvents();
    });

    sortSelect?.addEventListener('change', () => {
      sortEvents();
    });

    filterEvents();
    sortEvents();
  });
</script>

<Layout title="Events">
  <!-- HERO -->

  <section class="events-hero">
    <div class="hero-overlay"></div>

    <div class="events-title">
      <h1>Events</h1>
    </div>
  </section>

  <Divider />

  <!-- OPENING HOURS -->

  <section class="opening-section">
    <h2>Our Opening hours</h2>

    <div class="opening-grid">
      <!-- BUREAU -->

      <div class="opening-card">
        <div class="opening-top">
          <div>
            <p>Brantebjerg Bureau</p>

            <span>Tullinsgade 25, 1618</span>
          </div>

          <div>
            <p>Åbningstider:</p>
          </div>
        </div>

        <div class="opening-times">
          <span>Mandag: 11-19</span>
          <span>Tirsdag: 11-19</span>
          <span>Onsdag: 11-19</span>
          <span>Torsdag: 11-19</span>
          <span>Fredag: 11-19</span>
          <span>Lørdag: 11-19</span>
          <span>Søndag: 11-19</span>
        </div>
      </div>

      <!-- KUNSTHAL -->

      <div class="opening-card">
        <div class="opening-top">
          <div>
            <p>Brantebjerg Kunsthal</p>

            <span>Nakke Nord 65, 4500</span>
          </div>

          <div>
            <p>Åbningstider:</p>
          </div>
        </div>

        <div class="opening-times">
          <span>Mandag: 11-19</span>
          <span>Tirsdag: 11-19</span>
          <span>Onsdag: 11-19</span>
          <span>Torsdag: 11-19</span>
          <span>Fredag: 11-19</span>
          <span>Lørdag: 11-19</span>
          <span>Søndag: 11-19</span>
        </div>
      </div>
    </div>
  </section>

  <!-- EVENTS -->

  <section class="events-section">
    <div class="events-top">
      <select class="filter">
        <option>All</option>
        <option>Brantebjerg Bureau</option>
        <option>Brantebjerg Kunsthal</option>
      </select>

      <select class="sort">
        <option>Ascending</option>
        <option>Descending</option>
      </select>

      <h2>Upcoming events</h2>
    </div>

    <div class="events-grid">
      {
        events.map((event: any) => (
          <article class="event-card" data-place={event.place?.toLowerCase().trim()} data-date={event.date || ''}>
            <div class="event-info">
              <div class="event-left">
                <span>{event.name}</span>

                <span>{event.date}</span>

                <span>{event.place}</span>
              </div>

              <div class="event-right">
                <p>{event.description}</p>
              </div>
            </div>

            <img src={event.picture} alt={event.name} />
          </article>
        ))
      }
    </div>
  </section>
</Layout>
